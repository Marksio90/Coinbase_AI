##############################################
# APP
##############################################
# Application environment identifier (dev/staging/prod).
APP_ENV=development
# Human-readable deployment name used in logs and monitoring.
APP_DEPLOYMENT_NAME=coinbase-ai-platform-dev
# Global log verbosity level for all services.
LOG_LEVEL=INFO
# Default timezone used for timestamps in app-level jobs.
APP_TIMEZONE=UTC

##############################################
# COINBASE
##############################################
# Coinbase Advanced Trade API base URL.
COINBASE_API_BASE_URL=https://api.coinbase.com
# Coinbase WebSocket v3 feed URL.
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
# Coinbase API key name (never commit real values).
COINBASE_API_KEY=cb_api_key_example
# Coinbase API private key in PEM format (use secret manager in production).
COINBASE_API_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nREPLACE_ME\n-----END EC PRIVATE KEY-----
# Coinbase portfolio UUID used by execution and reporting services.
COINBASE_PORTFOLIO_ID=00000000-0000-0000-0000-000000000000
# Request timeout for Coinbase REST calls in seconds.
COINBASE_HTTP_TIMEOUT_SECONDS=10

##############################################
# OPENAI
##############################################
# OpenAI API base URL for model inference.
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI API key (example only; store real key in secrets backend).
OPENAI_API_KEY=sk-example-not-a-real-key
# Primary reasoning model for AI agents.
OPENAI_MODEL_PRIMARY=gpt-5.1
# Secondary/fallback model for resilience.
OPENAI_MODEL_FALLBACK=gpt-4.1-mini
# Request timeout for OpenAI calls in seconds.
OPENAI_TIMEOUT_SECONDS=30
# Maximum retries for transient OpenAI failures.
OPENAI_MAX_RETRIES=3

##############################################
# TRADING
##############################################
# Trading mode selector: paper (simulated) or live (real orders).
TRADING_MODE=paper
# Global feature flag for AI-driven analytics/decision support.
ENABLE_AI=true
# Global feature flag allowing strategy-generated trade intents.
ENABLE_TRADING=true
# Global feature flag enabling execution engine order submission.
ENABLE_EXECUTION=false
# Default quote currency for portfolio calculations.
TRADING_DEFAULT_QUOTE_CURRENCY=USD
# Comma-separated symbols universe available to strategy layer.
TRADING_ALLOWED_SYMBOLS=BTC-USD,ETH-USD,SOL-USD
# Candle timeframe for strategy evaluation loops.
TRADING_DEFAULT_TIMEFRAME=1m
# Maximum number of concurrent open positions across all symbols.
TRADING_MAX_OPEN_POSITIONS=5

##############################################
# RISK
##############################################
# Maximum notional (USD) allowed per order by risk engine.
RISK_MAX_NOTIONAL_USD=1000
# Hard daily loss stop in USD; trading halts when breached.
RISK_DAILY_MAX_LOSS_USD=500
# Max allowed account drawdown as fraction (e.g., 0.10 = 10%).
RISK_MAX_DRAWDOWN_PCT=0.10
# Max AI confidence threshold for unattended execution approval.
RISK_MAX_AI_CONFIDENCE_AUTO=0.92
# Comma-separated product whitelist enforced by risk engine.
RISK_ALLOWED_SYMBOLS=BTC-USD,ETH-USD
# Maximum number of risk check retries for transient dependency errors.
RISK_CHECK_MAX_RETRIES=2

##############################################
# EXECUTION
##############################################
# Comma-separated list of services authorized to call execution endpoint.
EXECUTION_ALLOWED_CALLERS=orchestrator
# Order request timeout in milliseconds for exchange submission.
EXECUTION_ORDER_TIMEOUT_MS=5000
# Maximum retry attempts for exchange order placement.
EXECUTION_MAX_RETRIES=3
# Base backoff delay in milliseconds for execution retries.
EXECUTION_RETRY_BASE_DELAY_MS=250
# Whether post-only behavior is preferred for eligible limit orders.
EXECUTION_DEFAULT_POST_ONLY=false
# Settlement mode for internal accounting (spot/futures-ready extension).
EXECUTION_SETTLEMENT_MODE=spot

##############################################
# REDIS
##############################################
# Redis hostname for event bus, cache, and lightweight state.
REDIS_HOST=redis
# Redis port number.
REDIS_PORT=6379
# Redis logical database index.
REDIS_DB=0
# Redis password (example placeholder only).
REDIS_PASSWORD=redis_password_example
# Enable TLS for Redis connections.
REDIS_TLS_ENABLED=false
# Prefix to isolate keys by environment/workspace.
REDIS_KEY_PREFIX=coinbase_ai:dev

##############################################
# POSTGRES
##############################################
# PostgreSQL hostname used by API and portfolio services.
POSTGRES_HOST=postgres
# PostgreSQL port.
POSTGRES_PORT=5432
# PostgreSQL database name.
POSTGRES_DB=coinbase_ai
# PostgreSQL username.
POSTGRES_USER=coinbase_ai_user
# PostgreSQL password (example only).
POSTGRES_PASSWORD=postgres_password_example
# SQLAlchemy/driver-ready DSN for services that use a single URL.
POSTGRES_DSN=postgresql+psycopg://coinbase_ai_user:postgres_password_example@postgres:5432/coinbase_ai
# Database connection pool size per service instance.
POSTGRES_POOL_SIZE=10

##############################################
# API
##############################################
# Public API bind host.
API_HOST=0.0.0.0
# Public API bind port.
API_PORT=8080
# CORS allowed origins list (comma-separated).
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# JWT issuer string used for token validation.
API_JWT_ISSUER=coinbase-ai-platform
# JWT audience value expected by API.
API_JWT_AUDIENCE=coinbase-ai-clients
# JWT public key placeholder for RS256 verification.
API_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----
# API rate limit per minute per client.
API_RATE_LIMIT_PER_MINUTE=120

##############################################
# FRONTEND
##############################################
# Frontend app environment marker.
FRONTEND_ENV=development
# Base URL for backend API consumed by dashboard.
FRONTEND_API_BASE_URL=http://localhost:8080
# Public URL where the frontend is served.
FRONTEND_PUBLIC_URL=http://localhost:3000
# Frontend default refresh interval for live widgets (milliseconds).
FRONTEND_REFRESH_INTERVAL_MS=3000
# Enable advanced risk widgets in dashboard UI.
FRONTEND_ENABLE_RISK_DASHBOARD=true

##############################################
# STORAGE
##############################################
# Root path for runtime state snapshots.
STORAGE_STATE_PATH=/app/storage/state
# Root path for strategy/backtest artifacts.
STORAGE_BACKTESTS_PATH=/app/storage/backtests
# Root path for exported reports and CSV dumps.
STORAGE_EXPORTS_PATH=/app/storage/exports
# Root path for log volume mounted in containers.
STORAGE_LOGS_PATH=/app/storage/logs
# Retention period in days for local artifacts.
STORAGE_RETENTION_DAYS=30

##############################################
# ALERTING
##############################################
# Enable alert dispatching pipeline.
ALERTING_ENABLED=true
# Slack incoming webhook URL placeholder.
ALERTING_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/EXAMPLE
# Email sender used for critical alerts.
ALERTING_EMAIL_FROM=alerts@coinbase-ai.example.com
# Comma-separated list of alert recipients.
ALERTING_EMAIL_TO=ops@coinbase-ai.example.com,risk@coinbase-ai.example.com
# Minimum severity level that triggers notifications.
ALERTING_MIN_SEVERITY=warning
# Timeout for outbound alert webhooks in seconds.
ALERTING_TIMEOUT_SECONDS=5
