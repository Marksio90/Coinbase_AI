# Coinbase Agent Platform environment template
# Copy this file to `.env` and fill in secrets via your secret manager.

# =========================
# Coinbase Advanced Trade API
# =========================
# API key name (identifier) for Coinbase Advanced Trade.
COINBASE_API_KEY=your_coinbase_api_key_name
# PEM-encoded private key used to sign Coinbase API requests.
COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nreplace_with_private_key\n-----END EC PRIVATE KEY-----"
# Base URL for Coinbase Advanced Trade REST API (production endpoint).
COINBASE_API_BASE_URL=https://api.coinbase.com
# WebSocket URL for Coinbase Advanced Trade market/user streams.
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com

# =========================
# OpenAI API
# =========================
# OpenAI API key used by AI agents (function calling / structured outputs).
OPENAI_API_KEY=sk-your-openai-api-key
# Default OpenAI model for decision-support tasks.
OPENAI_MODEL=gpt-4.1

# =========================
# Trading universe
# =========================
# Comma-separated list of enabled spot product IDs (Coinbase format).
TRADING_PAIRS=BTC-EUR,ETH-EUR,SOL-EUR,XRP-EUR

# =========================
# Risk management (risk-first)
# =========================
# Fraction of account equity risked per trade (e.g., 0.005 = 0.5%).
RISK_PER_TRADE=0.005
# Maximum allowed daily drawdown in percent before trading is halted.
MAX_DAILY_LOSS_PCT=2.0
# Stop-loss distance in percent from entry price.
STOP_LOSS_PCT=1.0
# Take-profit distance in percent from entry price.
TAKE_PROFIT_PCT=2.0
# Trailing stop distance in percent used after position moves in favor.
TRAILING_STOP_PCT=0.8

# =========================
# Infrastructure
# =========================
# Redis connection string for pub/sub, state cache, and event bus.
REDIS_URL=redis://redis:6379/0
# PostgreSQL connection string for orders, fills, risk, and audit data.
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/coinbase_ai

# =========================
# Observability
# =========================
# Application log verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
